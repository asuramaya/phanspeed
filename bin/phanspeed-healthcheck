"""phanspeed-healthcheck — restart phanspeedd if it's inactive or wedged
(status stale, or the control socket stopped answering). Run periodically
by phanspeed-healthcheck.timer.

Thin wrapper over sutra.check_health() (UNIFY.md health helper, sutra
0.4.0): the freshness/ping verdict is the shared family formula, not a
phanspeed-specific magic number. Passive by itself — restarting on a bad
verdict is this bin's own call, same as before.
"""
import os
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import sutra  # noqa: E402

STATUS_PATH = "/run/phanspeed/status.json"
SOCK_PATH = "/run/phanspeed/control.sock"
DEFAULT_POLL = 3.0  # phanspeed's own DEFAULTS["poll_interval"] — fallback only;
                    # status.json always carries the real value once written


def restart(reason):
    print(f"[healthcheck] {reason} — restarting phanspeed")
    subprocess.run(["systemctl", "restart", "phanspeed"])


def main():
    r = subprocess.run(["systemctl", "is-active", "--quiet", "phanspeed"])
    if r.returncode != 0:
        restart("service not active")
        return 0

    healthy, reason, info = sutra.check_health(
        STATUS_PATH, SOCK_PATH, default_poll=DEFAULT_POLL)
    if not healthy:
        restart(reason)
        return 0

    print(f"[healthcheck] ok (status {info['age']:.0f}s old)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
