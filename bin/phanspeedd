#!/usr/bin/env python3
# SPDX-License-Identifier: GPL-3.0-or-later
# Copyright (C) 2026 asuramaya and PhanSpeed contributors
"""
phanspeedd — Dell thermal-profile control daemon (Precision / XPS).

Direct pwm/RPM control is firmware-locked on modern Dells (the EC rejects
pwm_enable changes with EINVAL), so the real cooling lever is the ACPI
platform_profile: cool / quiet / balanced / performance. This daemon owns
that knob and adds a temperature-driven auto policy on top of it — the
closest equivalent to a fan curve the hardware allows.

  * manual mode : hold a fixed profile.
  * auto mode   : step quiet -> balanced -> cool as a sensor heats up,
                  with hysteresis so it doesn't flap at the boundaries.
  * emergency   : force the most-aggressive cooling profile once a CPU
                  sensor crosses emergency_temp, latched until it falls
                  below emergency_clear_temp.
  * on exit/crash, the profile is restored to 'balanced'.

Status : a world-readable JSON snapshot at /run/phanspeed/status.json that the
         Quick Settings extension polls (no privilege needed to read).
Control: line-delimited JSON over /run/phanspeed/control.sock (mode 0666).
Config : /etc/phanspeed/config.json (hot-reloaded).
"""

import atexit
import glob
import json
import os
import shutil
import signal
import socket
import struct
import subprocess
import sys
import threading
import time
import traceback

RUN_DIR = "/run/phanspeed"
SOCK_PATH = "/run/phanspeed/control.sock"
STATUS_PATH = "/run/phanspeed/status.json"
CONFIG_PATH = "/etc/phanspeed/config.json"

VERSION_PATHS = ("/usr/share/phanspeed/VERSION",
                 os.path.join(os.path.dirname(os.path.dirname(
                     os.path.abspath(__file__))), "VERSION"))

PROFILE_PATH = "/sys/firmware/acpi/platform_profile"
CHOICES_PATH = "/sys/firmware/acpi/platform_profile_choices"

RAPL_GLOB = "/sys/class/powercap/intel-rapl:*"   # package domains live here
RAPL_MMIO_GLOB = "/sys/class/powercap/intel-rapl-mmio:*"  # 2nd, separately
                                                  # enforced PL1 register — see
                                                  # Hardware._discover_rapl
PL_MIN_W = 8                                       # never cap below this (usability)
PL_MAX_W = 250                                      # absolute sanity ceiling

# NOTE: Dell hides a lower package PL1 in a chipset MMIO register that the MSR/
# sysfs view doesn't reflect (the hardware obeys the lower of the two). We
# deliberately do NOT touch it: reaching it needs /dev/mem + CAP_SYS_RAWIO, far
# too dangerous a privilege for a long-running root service to hold, and the EC
# re-asserts it every ~15 s anyway. Lift that cap via the BIOS thermal/power
# policy instead (e.g. dell-wmi-sysman ThermalManagement). phanspeed governs only
# the MSR/sysfs PL1, which needs no special capability.

# Turbo (Intel/AMD boost) and HWP energy/performance preference — extra,
# always-optional CPU levers. Both are plain sysfs writes (no capability needed).
TURBO_PATH = "/sys/devices/system/cpu/intel_pstate/no_turbo"   # 1 = turbo OFF
CPU_GLOB = "/sys/devices/system/cpu/cpu[0-9]*"
EPP_LEAF = "cpufreq/energy_performance_preference"
EPP_AVAIL_LEAF = "cpufreq/energy_performance_available_preferences"
# kernel-standard EPP strings; validated without touching hardware (so the
# config fuzz test needs no live CPU). set_epp() additionally checks what the
# running kernel actually offers.
VALID_EPP = {"default", "performance", "balance_performance",
             "balance_power", "power"}

# preferred profile name per cooling level (first match in choices wins)
LEVEL_NAMES = {
    0: ["quiet", "low-power", "power-saver", "balanced"],          # calmest fans
    1: ["balanced", "balanced-performance", "quiet"],             # middle
    2: ["cool", "performance", "balanced-performance", "balanced"],  # max cooling
}
RESTORE_NAMES = ["balanced", "balanced-performance", "quiet"]

# Missions — the three stances PhanSpeed takes against the three things that
# cripple a laptop. Each redefines the control objective:
#   cool    — survive heat: cap watts at the source, quiet/cool fans.
#   perf    — unleash: full power, performance EPP, turbo where allowed.
#   endure  — survive power: minimise total draw to live on a trickle. Closed-
#             loop CPU cap hunts toward break-even (net battery drain <= 0),
#             suspends the dGPU, and (high intensity) dims the panel + kbd.
# `intensity` (0..4) is how hard you lean into the active mission's objective.
MISSIONS = ("cool", "perf", "endure")
INTENSITY_MAX = 4
# Software thermal failsafe. With a healthy CPU fan the chip's normal operating
# ceiling *is* Tjmax (~100 °C) — the silicon throttles itself there in hardware,
# by design, under any sustained load. So a software "emergency" at/under Tjmax
# just fights the hardware with a redundant clamp and thrashes the stance every
# load burst. With a fan spinning we therefore trust the hardware Tjmax throttle
# and set the trip ABOVE any reachable temperature: it only fires on a genuine
# sensor runaway (cooling so gone the reading climbs past Tjmax). With no active
# cooling (the dead CPU-fan scenario this failsafe was born for) we fall back to
# the conservative, instant-trip configured emergency_temp — full protection.
EMERGENCY_FAN_OK_TEMP = 105     # °C — unreachable under HW Tjmax throttle (fan ok)
EMERGENCY_DEBOUNCE = 3          # consecutive over-temp samples before tripping (fan ok)
# A real dead fan reads 0 rpm *persistently*; the Dell dell_smm RPM read is a slow
# BIOS SMI call that can momentarily glitch to 0/unreadable under heavy all-core
# load — exactly when the chip is at Tjmax. Believing one glitch would drop us to
# the aggressive instant trip and fire a false emergency. So treat the fan as dead
# only after this many *consecutive* dead reads.
FAN_DEAD_DEBOUNCE = 4           # consecutive dead-fan reads before trusting it

# Endure extra levers: discrete-GPU runtime PM + panel/keyboard trims.
PCI_DEVICES = "/sys/bus/pci/devices"
NVIDIA_VENDOR = "0x10de"
BACKLIGHT_GLOB = "/sys/class/backlight/*"
KBD_LED_GLOB = "/sys/class/leds/*kbd_backlight*"
ENDURE_DIM_FRAC = 0.30          # panel brightness while "at all costs" trims run

DEFAULTS = {
    "poll_interval": 3.0,
    "mode": "auto",                 # auto | manual
    "manual_profile": "balanced",
    "sensor": "auto",               # "auto" = hottest CPU sensor
    "quiet_below": 60,              # < this  -> quiet
    "cool_above": 80,              # > this  -> cool ; between -> balanced
    "hysteresis": 4,
    "emergency_temp": 90,
    "emergency_clear_temp": 78,
    "allow_uids": [],               # UIDs allowed to control (root always allowed)
    "rate_limit": 10,               # max config-changing commands per 10s window
    "power_limit_w": 0,             # CPU PL1 cap in W; 0 = unmanaged (leave default)
    "power_auto": False,            # scale the CPU power cap with temperature
    "power_floor_w": 0,             # cap when hot under power_auto; 0 = base TDP
    "battery_aware": False,         # force a calm profile + low power on battery
    "battery_profile": "quiet",     # profile to use while on battery
    "battery_power_w": 0,           # tuned CPU cap on battery; 0 = base TDP
    "turbo": "auto",                # auto = leave alone | on | off (force boost)
    "epp": "",                      # AC/default EPP; "" = leave alone
    "battery_epp": "",              # EPP on battery; "" = balance_power fallback
    "gpu_power_limit_w": 0,         # NVIDIA GPU power cap in W; 0 = unmanaged
    "gpu_persistence": False,       # nvidia-smi -pm 1 (keeps driver loaded; desktops)
    "mission": "",                  # "" = legacy (mode/profile) | cool | perf | endure
    "intensity": 2,                 # 0..4 — lean within the active mission
    "endure_gpu_sleep": True,       # Endure: let the dGPU runtime-suspend (big win)
    "endure_trim": True,            # Endure "at all costs": dim panel + kbd off
}

# Hard safety bounds for socket-settable numeric fields. The control socket is
# world-writable (0666), so EVERY value coming from it is treated as hostile and
# clamped here — in particular emergency_temp is hard-capped so the thermal
# failsafe can never be disabled by a local process.
NUM_LIMITS = {
    "quiet_below": (30, 85),
    "cool_above": (40, 90),
    "hysteresis": (0, 15),
    "emergency_temp": (60, 95),          # hard ceiling 95 °C — cannot be raised away
    "emergency_clear_temp": (40, 90),
}
MAX_MSG_BYTES = 64 * 1024                 # cap socket reads to avoid memory DoS


def _coerce_num(v, lo, hi):
    """Return v clamped to [lo, hi] if it's a real number, else None.
    Rejects bools, strings, NaN/inf."""
    if isinstance(v, bool) or not isinstance(v, (int, float)):
        return None
    if v != v or v in (float("inf"), float("-inf")):
        return None
    return max(lo, min(hi, v))


def sanitize_config(cfg, choices, sensors):
    """Clamp/validate every field and enforce failsafe invariants in place.
    Applied on load AND after every socket set, so neither a tampered config
    file nor a hostile socket client can ever leave the daemon in an unsafe or
    crashing state."""
    for k, (lo, hi) in NUM_LIMITS.items():
        v = _coerce_num(cfg.get(k), lo, hi)
        cfg[k] = v if v is not None else DEFAULTS[k]
    if cfg.get("mode") not in ("auto", "manual"):
        cfg["mode"] = DEFAULTS["mode"]
    if cfg.get("manual_profile") not in choices:
        cfg["manual_profile"] = choices[0] if choices else DEFAULTS["manual_profile"]
    s = cfg.get("sensor")
    if not (isinstance(s, str) and (s == "auto" or s in sensors)):
        cfg["sensor"] = "auto"
    au = cfg.get("allow_uids")
    cfg["allow_uids"] = ([int(u) for u in au
                          if isinstance(u, int) and not isinstance(u, bool)]
                         if isinstance(au, list) else [])
    rl = _coerce_num(cfg.get("rate_limit"), 1, 1000)
    cfg["rate_limit"] = int(rl) if rl is not None else DEFAULTS["rate_limit"]
    # power limits: 0 = unmanaged, otherwise clamp to a usable, sane window
    def _clamp_power(v):
        if _coerce_num(v, 0, PL_MAX_W) is None or v == 0:
            return 0
        return int(max(PL_MIN_W, min(PL_MAX_W, v)))
    cfg["power_limit_w"] = _clamp_power(cfg.get("power_limit_w"))
    cfg["power_floor_w"] = _clamp_power(cfg.get("power_floor_w"))
    cfg["battery_power_w"] = _clamp_power(cfg.get("battery_power_w"))
    cfg["gpu_power_limit_w"] = _clamp_power(cfg.get("gpu_power_limit_w"))
    cfg["power_auto"] = bool(cfg.get("power_auto")) if isinstance(
        cfg.get("power_auto"), bool) else False
    cfg["battery_aware"] = bool(cfg.get("battery_aware")) if isinstance(
        cfg.get("battery_aware"), bool) else False
    cfg["gpu_persistence"] = bool(cfg.get("gpu_persistence")) if isinstance(
        cfg.get("gpu_persistence"), bool) else False
    if cfg.get("battery_profile") not in choices:
        cfg["battery_profile"] = ("quiet" if "quiet" in choices
                                  else (choices[0] if choices else "quiet"))
    if cfg.get("turbo") not in ("auto", "on", "off"):
        cfg["turbo"] = "auto"
    for ek in ("epp", "battery_epp"):
        ev = cfg.get(ek)
        if not (isinstance(ev, str) and (ev == "" or ev in VALID_EPP)):
            cfg[ek] = ""
    if cfg.get("mission") not in ("",) + MISSIONS:
        cfg["mission"] = ""
    iv = _coerce_num(cfg.get("intensity"), 0, INTENSITY_MAX)
    cfg["intensity"] = int(iv) if iv is not None else DEFAULTS["intensity"]
    for bk in ("endure_gpu_sleep", "endure_trim"):
        cfg[bk] = bool(cfg.get(bk)) if isinstance(cfg.get(bk), bool) else DEFAULTS[bk]
    # invariants — the failsafe must always be meaningful
    cfg["emergency_temp"] = min(cfg["emergency_temp"], NUM_LIMITS["emergency_temp"][1])
    if cfg["emergency_clear_temp"] >= cfg["emergency_temp"]:
        cfg["emergency_clear_temp"] = cfg["emergency_temp"] - 2
    if cfg["cool_above"] <= cfg["quiet_below"]:
        cfg["cool_above"] = cfg["quiet_below"] + 1
    return cfg


def read_version():
    for p in VERSION_PATHS:
        try:
            with open(p) as f:
                v = f.read().strip()
            if v:
                return v
        except OSError:
            continue
    return None


def log(msg):
    sys.stdout.write(f"[phanspeed] {msg}\n")
    sys.stdout.flush()


# --------------------------------------------------------------------------- #
# sysfs helpers
# --------------------------------------------------------------------------- #
def _read(path):
    try:
        with open(path) as f:
            return f.read().strip()
    except OSError:
        return None


def _read_int(path):
    v = _read(path)
    try:
        return int(v)
    except (TypeError, ValueError):
        return None


def _sticky_fan_ok(raw_alive, dead_streak, debounce):
    """Debounce the 'is a CPU fan spinning?' signal. A truly dead fan reads 0 rpm
    poll after poll; a transient SMI glitch reads 0 once. Return
    (fan_ok, new_dead_streak): the fan counts as alive until it has read dead for
    `debounce` consecutive polls, so one glitch can't drop us to the aggressive
    failsafe trip."""
    dead_streak = 0 if raw_alive else dead_streak + 1
    return (dead_streak < debounce, dead_streak)


def _write(path, value):
    try:
        with open(path, "w") as f:
            f.write(str(value))
        return True
    except OSError as e:
        log(f"write failed {path} <- {value}: {e}")
        return False


def find_hwmon(name):
    for d in sorted(glob.glob("/sys/class/hwmon/hwmon*")):
        if _read(os.path.join(d, "name")) == name:
            return d
    return None


# --------------------------------------------------------------------------- #
# Hardware: sensors, fan RPM readback, and the platform_profile knob
# --------------------------------------------------------------------------- #
class Hardware:
    def __init__(self):
        if not os.path.exists(PROFILE_PATH):
            raise SystemExit("platform_profile not available — no controllable knob.")
        self.choices = (_read(CHOICES_PATH) or "balanced").split()
        self.smm = find_hwmon("dell_smm")
        self.ddv = find_hwmon("dell_ddv")
        self.coretemp = find_hwmon("coretemp")
        self.fans = self._discover_fans()
        self.sensors = self._discover_sensors()
        self.crit_sensor_ids = [
            sid for sid in self.sensors
            if "package" in sid.lower() or sid.lower().endswith(":cpu")
        ] or list(self.sensors)
        # resolve each cooling level to a concrete, available profile name
        self.level_profile = {}
        for lvl, names in LEVEL_NAMES.items():
            self.level_profile[lvl] = next(
                (n for n in names if n in self.choices), self.choices[0])
        self._discover_rapl()
        self._discover_cpu_pref()
        self._discover_cpufreq()
        self._discover_display()
        self.gpu = Gpu()

    # ---- RAPL CPU power limit (PL1) ---- #
    def _discover_rapl(self):
        """Find the package RAPL domain(s) and their writable PL1 node(s).
        Alder Lake+ mobile CPUs expose PL1 through two independent hardware
        registers — the legacy MSR interface (intel-rapl) and a separate MMIO
        interface (intel-rapl-mmio) — and the silicon enforces whichever of
        the two is LOWER. Only managing the MSR one (as this used to) leaves
        the MMIO one's own conservative factory default as the real, silent
        ceiling no matter what the MSR side is set to. Both must be written
        together."""
        self.rapl_pl1 = None            # MSR: constraint_0_power_limit_uw
        self.rapl_pl1_mmio = None       # MMIO: constraint_0_power_limit_uw
        self.power_base_w = None        # spec/base TDP (W)
        self.power_default_uw = None       # as-found MSR PL1, to restore on exit
        self.power_default_uw_mmio = None  # as-found MMIO PL1, to restore on exit
        self.energy_uj_path = None      # cumulative package energy counter (for actual W)
        self.energy_max_range_uj = None  # counter wraps at this value
        for d in sorted(glob.glob(RAPL_GLOB)):
            name = _read(os.path.join(d, "name")) or ""
            if not name.startswith("package"):
                continue
            pl1 = os.path.join(d, "constraint_0_power_limit_uw")
            if not (os.path.exists(pl1) and os.access(pl1, os.W_OK)):
                continue
            self.rapl_pl1 = pl1
            self.power_default_uw = _read_int(pl1)
            base = _read_int(os.path.join(d, "constraint_0_max_power_uw"))
            self.power_base_w = round(base / 1e6) if base else None
            eu = os.path.join(d, "energy_uj")
            if os.path.exists(eu):
                self.energy_uj_path = eu
                self.energy_max_range_uj = _read_int(
                    os.path.join(d, "max_energy_range_uj"))
            break
        for d in sorted(glob.glob(RAPL_MMIO_GLOB)):
            name = _read(os.path.join(d, "name")) or ""
            if not name.startswith("package"):
                continue
            pl1 = os.path.join(d, "constraint_0_power_limit_uw")
            if not (os.path.exists(pl1) and os.access(pl1, os.W_OK)):
                continue
            self.rapl_pl1_mmio = pl1
            self.power_default_uw_mmio = _read_int(pl1)
            break

    @property
    def has_power(self):
        return self.rapl_pl1 is not None

    def get_power_w(self):
        """The lower of the two domains — whichever the hardware is actually
        enforcing right now, not just what the MSR side claims."""
        if not self.has_power:
            return None
        vals = [v for v in (
            _read_int(self.rapl_pl1),
            _read_int(self.rapl_pl1_mmio) if self.rapl_pl1_mmio else None,
        ) if v]
        return round(min(vals) / 1e6) if vals else None

    def set_power_w(self, watts):
        if not self.has_power:
            return False
        watts = max(PL_MIN_W, min(PL_MAX_W, int(watts)))
        uw = int(watts * 1_000_000)
        ok = True
        if _read_int(self.rapl_pl1) != uw:
            ok = _write(self.rapl_pl1, uw) and ok
        if self.rapl_pl1_mmio and _read_int(self.rapl_pl1_mmio) != uw:
            ok = _write(self.rapl_pl1_mmio, uw) and ok
        return ok

    def restore_power(self):
        if self.has_power and self.power_default_uw:
            _write(self.rapl_pl1, self.power_default_uw)
        if self.rapl_pl1_mmio and self.power_default_uw_mmio:
            _write(self.rapl_pl1_mmio, self.power_default_uw_mmio)

    # ---- turbo / boost + HWP energy-perf preference (EPP) ---- #
    def _discover_cpu_pref(self):
        self.turbo_path = (TURBO_PATH if os.path.exists(TURBO_PATH)
                           and os.access(TURBO_PATH, os.W_OK) else None)
        # Turbo is uncontrollable only when the firmware REJECTS the write
        # (no_turbo node present but EPERM/EIO — i.e. Turbo Boost disabled in BIOS).
        # In that case set_turbo() latches this and the pill hides the switch. A
        # write that is accepted is honored — there is no EC "revert" to chase.
        self.turbo_locked = False
        # per-cpu EPP nodes + the kernel's offered preference list
        self.epp_paths = []
        self.epp_choices = []
        for d in sorted(glob.glob(CPU_GLOB)):
            p = os.path.join(d, EPP_LEAF)
            if os.path.exists(p) and os.access(p, os.W_OK):
                self.epp_paths.append(p)
        if self.epp_paths:
            avail = _read(os.path.join(os.path.dirname(os.path.dirname(
                self.epp_paths[0])), EPP_AVAIL_LEAF))
            self.epp_choices = [c for c in (avail or "").split() if c in VALID_EPP]

    # ---- CPU frequency readback (for power-clamp detection) ---- #
    def _discover_cpufreq(self):
        self.freq_cur_paths = sorted(
            glob.glob("/sys/devices/system/cpu/cpu[0-9]*/cpufreq/scaling_cur_freq"))
        self._freq_min_path = "/sys/devices/system/cpu/cpu0/cpufreq/scaling_min_freq"
        self._freq_max_path = "/sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq"

    @property
    def has_cpufreq(self):
        return bool(self.freq_cur_paths)

    def cpu_freq_mhz(self):
        """(highest current core MHz, min MHz, max MHz) or (None, None, None)."""
        if not self.has_cpufreq:
            return (None, None, None)
        cur = [_read_int(p) for p in self.freq_cur_paths]
        cur = [c for c in cur if c]
        if not cur:
            return (None, None, None)
        fmin = _read_int(self._freq_min_path) or 0
        fmax = _read_int(self._freq_max_path) or 0
        return (max(cur) // 1000, fmin // 1000, fmax // 1000)

    # ---- panel + keyboard backlight (Endure "at all costs" trims) ---- #
    def _discover_display(self):
        self.backlight = None        # (brightness_path, max) of the panel
        for d in sorted(glob.glob(BACKLIGHT_GLOB)):
            bp = os.path.join(d, "brightness")
            mx = _read_int(os.path.join(d, "max_brightness"))
            if os.access(bp, os.W_OK) and mx:
                self.backlight = (bp, mx)
                break
        self.kbd_leds = [os.path.join(d, "brightness")
                         for d in sorted(set(glob.glob(KBD_LED_GLOB)))
                         if os.access(os.path.join(d, "brightness"), os.W_OK)]
        self._trim_saved = None      # (panel_brightness, {kbd_path: brightness})

    def dim(self, frac=ENDURE_DIM_FRAC):
        """Drop panel + keyboard backlight, remembering the prior levels once."""
        if self._trim_saved is None:
            saved_panel = self.backlight and _read_int(self.backlight[0])
            saved_kbd = {p: _read_int(p) for p in self.kbd_leds}
            self._trim_saved = (saved_panel, saved_kbd)
        if self.backlight:
            bp, mx = self.backlight
            cur = _read_int(bp)
            target = max(1, int(mx * frac))
            if cur is None or cur > target:     # only ever dim, never brighten
                _write(bp, target)
        for p in self.kbd_leds:
            _write(p, 0)

    def undim(self):
        """Restore the panel + keyboard backlight saved by the first dim()."""
        if self._trim_saved is None:
            return
        panel, kbd = self._trim_saved
        if self.backlight and panel is not None:
            _write(self.backlight[0], panel)
        for p, v in kbd.items():
            if v is not None:
                _write(p, v)
        self._trim_saved = None

    @property
    def has_turbo(self):
        return self.turbo_path is not None and not self.turbo_locked

    @property
    def has_epp(self):
        return bool(self.epp_paths)

    def get_turbo(self):
        """True = turbo enabled (no_turbo == 0); None if no/locked knob."""
        if self.turbo_path is None:
            return None
        v = _read_int(self.turbo_path)
        return (v == 0) if v is not None else None

    def set_turbo(self, on):
        if not self.has_turbo:
            return False
        want = "0" if on else "1"
        if _read(self.turbo_path) == want:
            return True
        if _write(self.turbo_path, want):
            return True
        # The write was outright REJECTED by the kernel/firmware (EPERM/EIO) — this
        # is the only genuine "no turbo" case: it's disabled in BIOS. Latch off so
        # we stop retrying and the pill drops the switch. (We do NOT treat a value
        # that simply reads back changed as a "revert" — that earlier heuristic
        # was firing on the daemon's own writes and falsely hid a working switch.)
        self.turbo_locked = True
        log("turbo control unavailable (disabled in BIOS?) — not retrying")
        return False

    def get_epp(self):
        return _read(self.epp_paths[0]) if self.has_epp else None

    def set_epp(self, pref):
        if not self.has_epp or pref not in self.epp_choices:
            return False
        ok = True
        for p in self.epp_paths:
            if _read(p) != pref:
                ok = _write(p, pref) and ok
        return ok

    def _discover_fans(self):
        fans = {}
        if not self.smm:
            return fans
        for fin in sorted(glob.glob(os.path.join(self.smm, "fan[0-9]*_input"))):
            idx = os.path.basename(fin).split("_")[0][3:]
            label = self.ddv and _read(os.path.join(self.ddv, f"fan{idx}_label"))
            fans[idx] = {"label": label or f"Fan {idx}", "rpm": fin}
        return fans

    def _discover_sensors(self):
        sensors = {}
        for hw, prefix in ((self.ddv, "dell_ddv"), (self.coretemp, "coretemp")):
            if not hw:
                continue
            for tin in sorted(glob.glob(os.path.join(hw, "temp[0-9]*_input")),
                              key=lambda p: int(os.path.basename(p).split("_")[0][4:])):
                n = os.path.basename(tin).split("_")[0][4:]
                label = _read(os.path.join(hw, f"temp{n}_label")) or f"temp{n}"
                sid = f"{prefix}:{label}"
                if sid in sensors:
                    sid = f"{sid} ({n})"
                sensors[sid] = tin
        return sensors

    def read_temp(self, sid):
        mc = _read_int(self.sensors.get(sid, ""))
        return mc / 1000.0 if mc is not None else None

    def read_rpm(self, idx):
        return _read_int(self.fans[idx]["rpm"])

    def cpu_fan_alive(self):
        """True if a CPU-cooling fan is actually spinning. Prefer fans whose
        label mentions the CPU; otherwise consider any fan. Used to relax the
        software failsafe — the conservative low trip point only makes sense when
        there is no active cooling (the dead-fan scenario it was born for)."""
        all_rpm, cpu_rpm = [], []
        for idx, f in self.fans.items():
            r = self.read_rpm(idx)
            if r is None:
                continue
            all_rpm.append(r)
            if "cpu" in (f.get("label") or "").lower():
                cpu_rpm.append(r)
        pool = cpu_rpm or all_rpm
        return any(r > 100 for r in pool)

    def max_crit_temp(self):
        vals = [self.read_temp(s) for s in self.crit_sensor_ids]
        vals = [v for v in vals if v is not None]
        return max(vals) if vals else None

    def on_battery(self):
        """True if running on battery. If no AC adapter is reported (desktop),
        treat as on AC."""
        mains = []
        for d in glob.glob("/sys/class/power_supply/*"):
            if _read(os.path.join(d, "type")) == "Mains":
                online = _read_int(os.path.join(d, "online"))
                if online is not None:
                    mains.append(online)
        return bool(mains) and not any(mains)

    def get_profile(self):
        return _read(PROFILE_PATH)

    def set_profile(self, name):
        if name not in self.choices:
            log(f"profile '{name}' not in choices {self.choices}")
            return False
        if self.get_profile() == name:
            return True
        return _write(PROFILE_PATH, name)


# --------------------------------------------------------------------------- #
# Discrete NVIDIA GPU (optional, via nvidia-smi)
# --------------------------------------------------------------------------- #
def _find_nvidia_smi():
    for p in ("/usr/bin/nvidia-smi", "/usr/local/bin/nvidia-smi", "/bin/nvidia-smi"):
        if os.access(p, os.X_OK):
            return p
    return shutil.which("nvidia-smi")


NVIDIA_SMI = _find_nvidia_smi()
_GPU_FIELDS = ("name,temperature.gpu,power.draw,utilization.gpu,"
               "enforced.power.limit,power.default_limit,"
               "power.min_limit,power.max_limit,"
               "clocks.sm,clocks.max.sm")


class Gpu:
    def __init__(self):
        self.available = False
        self.name = None
        self.min_w = self.max_w = self.default_w = None
        self._cache = None
        self._cache_t = 0.0
        self._discover_pci()
        if not NVIDIA_SMI:
            return
        info = self.query(max_age=0)
        if info:
            self.available = True
            self.name = info.get("name")
            self.min_w = info.get("min")
            self.max_w = info.get("max")
            self.default_w = info.get("default")

    # ---- runtime power management (let the dGPU drop to D3cold when idle) ---- #
    def _discover_pci(self):
        """Find the NVIDIA PCI function(s) so we can drive runtime PM directly —
        this works even where nvidia-smi -pl is firmware-locked, and it's the
        single biggest idle-power lever on an Optimus laptop (the dGPU otherwise
        burns several watts at 0% util). Note: nvidia-persistenced, if running,
        pins the GPU on and defeats this — Endure still sets control=auto."""
        self.pci_control = []        # writable .../power/control paths
        self._pci_saved = {}         # original control values, for restore
        try:
            devs = sorted(glob.glob(os.path.join(PCI_DEVICES, "*")))
        except OSError:
            devs = []
        for d in devs:
            if _read(os.path.join(d, "vendor")) != NVIDIA_VENDOR:
                continue
            cls = _read(os.path.join(d, "class")) or ""
            if not cls.startswith("0x03"):     # display controller only
                continue
            ctl = os.path.join(d, "power", "control")
            if os.access(ctl, os.W_OK):
                self.pci_control.append(ctl)

    @property
    def has_runtime_pm(self):
        return bool(self.pci_control)

    def runtime_status(self):
        """'suspended' / 'active' for the dGPU (first function), or None."""
        if not self.pci_control:
            return None
        return _read(os.path.join(os.path.dirname(
            os.path.dirname(self.pci_control[0])), "power", "runtime_status"))

    def set_runtime_pm(self, allow):
        """allow=True -> 'auto' (may suspend when idle); False -> restore prior."""
        if not self.pci_control:
            return False
        ok = True
        for ctl in self.pci_control:
            if allow:
                self._pci_saved.setdefault(ctl, _read(ctl))
                if _read(ctl) != "auto":
                    ok = _write(ctl, "auto") and ok
            else:
                prev = self._pci_saved.pop(ctl, None)
                if prev and _read(ctl) != prev:
                    ok = _write(ctl, prev) and ok
        return ok

    def _run(self, args, timeout):
        try:
            return subprocess.run([NVIDIA_SMI, *args], capture_output=True,
                                  text=True, timeout=timeout)
        except Exception as e:
            log(f"nvidia-smi failed: {e}")
            return None

    def query(self, max_age=1.0):
        now = time.monotonic()
        if self._cache is not None and now - self._cache_t < max_age:
            return self._cache
        # Never poke nvidia-smi while the dGPU is runtime-suspended: the call can
        # block for the full timeout (stalling the control loop) and can even wake
        # the GPU, defeating the Endure sleep lever. A sleeping GPU has no
        # telemetry worth waking it for — report it as asleep instead.
        if self.runtime_status() == "suspended":
            return None
        r = self._run(["--query-gpu=" + _GPU_FIELDS,
                       "--format=csv,noheader,nounits", "-i", "0"], timeout=2)
        if not r or r.returncode != 0 or not r.stdout.strip():
            return None
        p = [x.strip() for x in r.stdout.strip().splitlines()[0].split(",")]
        if len(p) < 10:
            return None

        def f(x):
            try:
                return float(x)
            except ValueError:
                return None
        info = {"name": p[0], "temp": f(p[1]), "draw": f(p[2]), "util": f(p[3]),
                "limit": f(p[4]), "default": f(p[5]), "min": f(p[6]), "max": f(p[7]),
                "clock": f(p[8]), "max_clock": f(p[9])}
        self._cache, self._cache_t = info, now
        return info

    def set_limit_w(self, watts):
        if not self.available or self.min_w is None:
            return False
        watts = int(max(self.min_w, min(self.max_w, watts)))
        r = self._run(["-pl", str(watts)], timeout=5)
        if r and r.returncode == 0:
            self._cache = None      # force re-read next query
            return True
        return False

    def set_persistence(self, on):
        if not self.available:
            return False
        r = self._run(["-pm", "1" if on else "0"], timeout=5)
        return bool(r and r.returncode == 0)

    def restore(self):
        if self.available and self.default_w:
            self.set_limit_w(self.default_w)


# --------------------------------------------------------------------------- #
# Auto policy: temperature -> cooling level, with hysteresis on the way down
# --------------------------------------------------------------------------- #
def target_level(temp, lo, hi, current, hyst):
    """0=quiet 1=balanced 2=cool. Upgrades immediately; downgrades only after
    temp falls a full `hyst` below the boundary, so it doesn't oscillate."""
    if temp >= hi:
        return 2
    if temp >= lo:
        return 2 if (current >= 2 and temp > hi - hyst) else 1
    # temp < lo
    if current >= 2 and temp > hi - hyst:
        return 2
    if current >= 1 and temp > lo - hyst:
        return 1
    return 0


# --------------------------------------------------------------------------- #
# Daemon
# --------------------------------------------------------------------------- #
class Daemon:
    def __init__(self):
        self.hw = Hardware()
        self.version = read_version()
        self.lock = threading.RLock()
        self.emergency = False
        self._emerg_hits = 0           # consecutive over-temp samples (failsafe debounce)
        self._fan_dead_streak = 0      # consecutive dead-fan reads (glitch debounce)
        self.level = 1                 # current auto cooling level
        self.applied_profile = self.hw.get_profile()
        self.config = self.load_config()
        self._stop = threading.Event()
        self._cmd_times = []           # timestamps of recent config-changing cmds
        self._power_dirty = False      # have we changed the CPU power limit?
        self._gpu_last_set = None       # last GPU power limit we wrote (W)
        self._gpu_dirty = False         # have we changed the GPU power limit?
        self._gpu_pm = False            # have we enabled GPU persistence mode?
        self._turbo_dirty = False       # have we changed the turbo state?
        self._epp_dirty = False         # have we changed the EPP preference?
        self._stat_prev = None          # last /proc/stat (idle, total) for busy%
        self._busy_pct = None           # CPU busy% over the last poll
        self._energy_prev = None        # last (energy_uj, monotonic_t) for CPU watts
        self._cpu_actual_w = None       # measured CPU package watts over the last poll
        self._bat_prev = None           # last (charge_uah, monotonic_t) for drain calc
        self._bat_w = None              # smoothed net battery power (+ charging)
        self._balance = None            # last computed power_balance() snapshot
        self._endure_cap = None         # current closed-loop Endure CPU cap (W)
        self._trim_dirty = False        # have we dimmed the panel/kbd?
        self._gpu_pm_dirty = False      # have we forced dGPU runtime PM to auto?
        log(f"profiles available: {self.hw.choices}")
        log(f"level map: {self.hw.level_profile}")
        log(f"fans: {[(i, f['label']) for i, f in self.hw.fans.items()]}")
        log(f"watchdog sensors: {self.hw.crit_sensor_ids}")

    # ---- config ---- #
    def load_config(self):
        cfg = dict(DEFAULTS)
        try:
            with open(CONFIG_PATH) as f:
                user = json.load(f)
            if isinstance(user, dict):
                cfg.update(user)
                log(f"loaded config from {CONFIG_PATH}")
            else:
                log("config not a JSON object, using defaults")
        except FileNotFoundError:
            log("no config file, using defaults")
        except Exception as e:
            log(f"bad config ({e}), using defaults")
        # never trust the file: clamp/validate before it reaches the control loop
        sanitize_config(cfg, self.hw.choices, self.hw.sensors)
        return cfg

    def save_config(self):
        with self.lock:
            os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
            data = json.dumps(self.config, indent=2)
            # idempotent: if the on-disk file already matches, skip the write (and
            # the log line) so a chatty client can't spam disk I/O or the journal.
            try:
                with open(CONFIG_PATH) as f:
                    if f.read() == data:
                        return
            except OSError:
                pass
            tmp = CONFIG_PATH + ".tmp"
            fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
            with os.fdopen(fd, "w") as f:
                f.write(data)
            os.replace(tmp, CONFIG_PATH)
        log("config saved")

    # ---- authorization / rate limiting ---- #
    def allowed_uids(self):
        """root + configured allow_uids. When none are configured, fall back to
        root + the single seat owner (the lowest-uid human session, the same uid
        the control socket is handed to) — NOT every logged-in session."""
        allowed = {0}
        cfg = self.config.get("allow_uids") or []
        allowed.update(cfg)
        if not cfg:
            owner = self._status_target_uid()
            if owner is not None:
                allowed.add(owner)
        return allowed

    def _rate_ok(self):
        now = time.monotonic()
        self._cmd_times = [t for t in self._cmd_times if now - t < 10.0]
        if len(self._cmd_times) >= self.config.get("rate_limit", 10):
            return False
        self._cmd_times.append(now)
        return True

    # ---- control ---- #
    def policy_temp(self):
        sid = self.config.get("sensor", "auto")
        if sid == "auto" or sid not in self.hw.sensors:
            return self.hw.max_crit_temp()
        return self.hw.read_temp(sid)

    def _sample_busy(self):
        """CPU busy% since the last call, from /proc/stat (idle+iowait vs total)."""
        try:
            with open("/proc/stat") as f:
                parts = [int(x) for x in f.readline().split()[1:]]
        except (OSError, ValueError):
            self._busy_pct = None
            return
        idle, total = parts[3] + parts[4], sum(parts)
        prev, self._stat_prev = self._stat_prev, (idle, total)
        if not prev:
            self._busy_pct = None
            return
        di, dt = idle - prev[0], total - prev[1]
        self._busy_pct = max(0.0, min(100.0, 100.0 * (1 - di / dt))) if dt > 0 else None

    def _sample_cpu_power(self):
        """Actual CPU package watts since the last call, from the RAPL energy
        counter (energy_uj) — the cap fields only say what's ALLOWED, this is
        what's really being drawn. Handles the counter wrapping at
        max_energy_range_uj."""
        if not self.hw.energy_uj_path:
            self._cpu_actual_w = None
            return
        e = _read_int(self.hw.energy_uj_path)
        now = time.monotonic()
        if e is None:
            self._cpu_actual_w = None
            return
        prev, self._energy_prev = self._energy_prev, (e, now)
        if not prev:
            self._cpu_actual_w = None
            return
        de, dt = e - prev[0], now - prev[1]
        if de < 0 and self.hw.energy_max_range_uj:
            de += self.hw.energy_max_range_uj
        self._cpu_actual_w = round(de / 1e6 / dt, 1) if dt > 0 and de >= 0 else None

    def clamp_status(self):
        """Detect a hardware power clamp: under real load the top core is pinned
        near the frequency floor while there's ample thermal headroom and the
        platform could clock much higher. The classic cause is BD PROCHOT from a
        power-budget shortfall — a USB-C device drawing power, an underpowered
        charger, or a battery limit — not heat."""
        cmax, fmin, fmax = self.hw.cpu_freq_mhz()
        out = {"clamped": False, "cur_max_mhz": cmax, "min_mhz": fmin,
               "max_mhz": fmax, "busy_pct": (round(self._busy_pct)
               if self._busy_pct is not None else None), "reason": ""}
        if cmax is None or not fmin or not fmax or self.emergency:
            return out
        crit = self.hw.max_crit_temp()
        cool = crit is None or crit < self.config["emergency_temp"] - 5
        if (self._busy_pct is not None and self._busy_pct >= 35
                and fmax > fmin * 1.5 and cmax <= fmin * 1.2 and cool):
            out["clamped"] = True
            out["reason"] = ("power budget — a USB-C device drawing power, an "
                             "underpowered charger, or a battery limit")
        return out

    def _bat_dir(self):
        """A '+1/-1/0' charge direction for the battery, from its status."""
        for d in glob.glob("/sys/class/power_supply/*"):
            if _read(os.path.join(d, "type")) != "Battery":
                continue
            st = _read(os.path.join(d, "status"))
            return 1 if st == "Charging" else (-1 if st == "Discharging" else 0), d
        return 0, None

    def power_balance(self):
        """The Endure mission's instrument: watts in from the charger, net
        battery power (+ charging / − draining), total system draw, and a
        runtime estimate. Call once per loop — it samples the charge gauge over
        time, so repeated calls within a poll would skew the delta."""
        # --- input from any online source (USB-C PD / barrel / Mains) ---
        power_in, have_in = 0.0, False
        for d in glob.glob("/sys/class/power_supply/*"):
            if _read(os.path.join(d, "type")) == "Battery":
                continue
            if _read_int(os.path.join(d, "online")) != 1:
                continue
            pw = _read_int(os.path.join(d, "power_now"))
            if pw is not None:
                power_in += pw / 1e6
                have_in = True
                continue
            cur = _read_int(os.path.join(d, "current_now"))
            volt = _read_int(os.path.join(d, "voltage_now"))
            if cur and volt:
                power_in += (cur / 1e6) * (volt / 1e6)
                have_in = True
        # --- battery: net power, signed (+ charging, − draining) ---
        bat_w = remaining_min = None
        sign, bd = self._bat_dir()
        status = None
        if bd:
            status = _read(os.path.join(bd, "status"))
            volt = _read_int(os.path.join(bd, "voltage_now")) or 0
            mag = None
            pw = _read_int(os.path.join(bd, "power_now"))
            if pw is not None:
                mag = pw / 1e6
            else:
                cur = _read_int(os.path.join(bd, "current_now"))
                if cur is not None and volt:
                    mag = (cur / 1e6) * (volt / 1e6)
            charge = _read_int(os.path.join(bd, "charge_now"))
            now = time.monotonic()
            if mag is not None:
                bat_w = round(sign * mag, 1)
            elif charge is not None and volt:
                # charge-only gauge (this Dell): derive rate from charge delta.
                prev = self._bat_prev
                if prev and now - prev[1] >= 1.0:
                    d_uah = charge - prev[0]
                    dt_h = (now - prev[1]) / 3600.0
                    if dt_h:
                        amps = (d_uah / 1e6) / dt_h
                        bat_w = round(abs(amps) * (volt / 1e6)
                                      * (1 if d_uah > 0 else -1), 1)
                self._bat_prev = (charge, now)
            # runtime estimate
            energy = _read_int(os.path.join(bd, "energy_now"))
            if energy is None and charge is not None and volt:
                energy = int(charge * volt / 1e6)        # uAh*uV/1e6 ≈ uWh
            if bat_w and energy:
                wh = energy / 1e6
                if bat_w < 0:
                    remaining_min = round(wh / abs(bat_w) * 60)
                else:
                    ef = _read_int(os.path.join(bd, "energy_full"))
                    if ef is None:
                        cf = _read_int(os.path.join(bd, "charge_full"))
                        ef = int(cf * volt / 1e6) if cf and volt else None
                    if ef:
                        remaining_min = round(max(0, (ef - energy) / 1e6) / bat_w * 60)
        if bat_w is not None:
            self._bat_w = bat_w if self._bat_w is None else round(
                0.6 * self._bat_w + 0.4 * bat_w, 1)
        draw = (round(power_in - self._bat_w, 1)
                if have_in and self._bat_w is not None else None)
        self._balance = {
            "in_w": round(power_in, 1) if have_in else None,
            "battery_w": self._bat_w,
            "draw_w": draw,
            "remaining_min": remaining_min,
            "status": status,
            "breakeven": self._bat_w is not None and self._bat_w >= 0,
        }
        return self._balance

    def apply_once(self):
        self._sample_busy()
        self._sample_cpu_power()
        self.power_balance()
        with self.lock:
            crit = self.hw.max_crit_temp()
            # fan-aware failsafe: with a CPU fan spinning, only a *sustained*
            # runaway near Tjmax should trip (high ceiling + debounce) so normal
            # boost spikes to 100 °C don't thrash the stance. With no active
            # cooling, fall back to the conservative configured trip, instantly.
            fan_ok, self._fan_dead_streak = _sticky_fan_ok(
                self.hw.cpu_fan_alive(), self._fan_dead_streak, FAN_DEAD_DEBOUNCE)
            if fan_ok:
                hi, lo, need = EMERGENCY_FAN_OK_TEMP, EMERGENCY_FAN_OK_TEMP - 10, EMERGENCY_DEBOUNCE
            else:
                hi, lo, need = (self.config["emergency_temp"],
                                self.config["emergency_clear_temp"], 1)
            if crit is not None:
                self._emerg_hits = self._emerg_hits + 1 if crit >= hi else 0
                if not self.emergency and self._emerg_hits >= need:
                    log(f"!! EMERGENCY {crit:.0f}°C >= {hi}°C "
                        f"(fan {'ok' if fan_ok else 'DEAD'}) — forcing max cooling")
                    self.emergency = True
                elif self.emergency and crit <= lo:
                    log(f"emergency cleared {crit:.0f}°C <= {lo}°C")
                    self.emergency = False
                    self._emerg_hits = 0

            battery = bool(self.config.get("battery_aware") and self.hw.on_battery())
            mission = self.config.get("mission", "")
            if mission in MISSIONS and not self.emergency:
                # a mission owns the whole stance (profile + power + pref + gpu)
                self._apply_mission(mission, self.config.get("intensity", 2), battery)
            else:
                self._endure_teardown()         # emergency/legacy: drop Endure trims
                if self.emergency:
                    self.hw.set_profile(self.hw.level_profile[2])
                    self._apply_power(emergency=True)
                elif battery:
                    bp = self.config.get("battery_profile")
                    self.hw.set_profile(bp if bp in self.hw.choices
                                        else self.hw.level_profile[0])
                    self._apply_power(emergency=False, battery=True)
                elif self.config["mode"] == "manual":
                    self.hw.set_profile(self.config["manual_profile"])
                    self._apply_power(emergency=False)
                else:  # auto
                    t = self.policy_temp()
                    if t is not None:
                        self.level = target_level(
                            t, self.config["quiet_below"], self.config["cool_above"],
                            self.level, self.config["hysteresis"])
                        self.hw.set_profile(self.hw.level_profile[self.level])
                    self._apply_power(emergency=False)
                self._apply_cpu_pref(self.emergency, battery)
                self._apply_gpu(self.emergency, battery)
            self.applied_profile = self.hw.get_profile()
        self.write_status()      # always publish (incl. during emergency)

    def _apply_cpu_pref(self, emergency, battery):
        """Drive turbo/boost and the HWP energy-perf preference. Both default to
        unmanaged ('auto'/''); emergency and battery force the cooler/lower-power
        direction. When we've touched a knob but it's unmanaged again, restore the
        firmware-neutral value (turbo on, EPP 'default') so an emergency doesn't
        silently leave boost disabled forever."""
        if self.hw.has_turbo:
            desired = None
            if emergency or battery:
                desired = False                       # boost off cuts heat/draw
            elif self.config["turbo"] == "on":
                desired = True
            elif self.config["turbo"] == "off":
                desired = False
            if desired is not None:
                self.hw.set_turbo(desired)
                self._turbo_dirty = True
            elif self._turbo_dirty:
                self.hw.set_turbo(True)               # neutral default = on
                self._turbo_dirty = False
        if self.hw.has_epp:
            pref = None
            if emergency:
                pref = "power"
            elif battery:
                pref = self.config.get("battery_epp") or "balance_power"
            elif self.config["epp"]:
                pref = self.config["epp"]
            if pref and pref in self.hw.epp_choices:
                self.hw.set_epp(pref)
                self._epp_dirty = True
            elif self._epp_dirty:
                if "default" in self.hw.epp_choices:
                    self.hw.set_epp("default")
                self._epp_dirty = False

    # ---- mission layer (cool / perf / endure presets over the raw knobs) ---- #
    def _set_cap(self, cap):
        """Apply (cap>0) or release (cap==0) the CPU PL1, tracking dirtiness."""
        if cap and cap > 0:
            self.hw.set_power_w(cap)
            self._power_dirty = True
        elif self._power_dirty:
            self.hw.restore_power()
            self._power_dirty = False

    def _set_turbo(self, desired):
        if not self.hw.has_turbo:
            return
        if desired is not None:
            self.hw.set_turbo(desired)
            self._turbo_dirty = True
        elif self._turbo_dirty:
            self.hw.set_turbo(True)
            self._turbo_dirty = False

    def _set_epp(self, pref):
        if not self.hw.has_epp:
            return
        if pref and pref in self.hw.epp_choices:
            self.hw.set_epp(pref)
            self._epp_dirty = True
        elif self._epp_dirty:
            if "default" in self.hw.epp_choices:
                self.hw.set_epp("default")
            self._epp_dirty = False

    def _apply_mission(self, mission, intensity, battery):
        intensity = max(0, min(INTENSITY_MAX, int(intensity)))
        if mission != "endure":
            self._endure_teardown()
        if mission == "cool":
            self._mission_cool(intensity)
        elif mission == "perf":
            self._mission_perf(intensity)
        elif mission == "endure":
            self._mission_endure(intensity)
        self._apply_gpu(False, battery)        # honor any GPU power cap config

    def _mission_cool(self, i):
        """Survive heat: cooler fans + lower watts as intensity rises."""
        self.hw.set_profile(self.hw.level_profile[2 if i >= 2 else 1])
        base = self.hw.power_base_w or 45
        self._set_cap([0, base, round(base * 0.8), round(base * 0.6),
                       round(base * 0.5)][i])
        self._set_turbo(False if i >= 3 else None)
        # cap cool's EPP at balance_power until the very top — full "power" pins
        # the chip to ~1 GHz and feels broken for everyday use.
        self._set_epp(["", "", "balance_power", "balance_power", "power"][i])

    def _mission_perf(self, i):
        """Unleash: max fans, turbo on, and LIFT the package power limit as
        intensity rises. Crucially this raises the limit (incl. the hidden MMIO
        cap) above the firmware default — 'release' would just fall back to Dell's
        conservative ~25 W. The chip self-limits thermally and the fan-aware
        failsafe is the backstop, so a high cap simply means 'run to the thermal
        wall', not 'burn down'. Deliberately does NOT use level_profile[2]
        (which picks 'cool' for its fan curve, shared with the Cool mission):
        on this Dell EC, platform_profile also gates the discrete GPU's power
        state, and 'cool' pins it to P8 (idle) regardless of load — silently
        strangling any concurrent GPU workload on a shared machine. Perf's
        whole point is unleashing, so it must never pick a profile named for
        restraint; 'performance' gives the same aggressive fan response
        without that side effect."""
        perf_profile = ("performance" if "performance" in self.hw.choices
                        else self.hw.level_profile[2])
        self.hw.set_profile(perf_profile)
        base = self.hw.power_base_w or 45
        self._set_cap([base, round(base * 1.2), round(base * 1.4),
                       round(base * 1.6), round(base * 1.8)][i])
        self._set_turbo(None if i == 0 else True)
        self._set_epp(["", "balance_performance", "performance",
                       "performance", "performance"][i])

    def _mission_endure(self, i):
        """Survive power: minimise draw, hunt the CPU cap toward break-even,
        sleep the dGPU, and (high intensity) dim the panel + kill the kbd light.
        This is the 'keep it alive on a trickle' mission."""
        self.hw.set_profile(self.hw.level_profile[0])          # quietest fans
        self._set_turbo(False)
        self._set_epp("power" if "power" in self.hw.epp_choices else
                      "balance_power" if "balance_power" in self.hw.epp_choices
                      else "")
        base = self.hw.power_base_w or 45
        # ceiling = perf you'll tolerate; floor = how thrifty this intensity goes
        ceil = [base, round(base * 0.7), round(base * 0.5),
                round(base * 0.4), round(base * 0.33)][i]
        floor = [round(base * 0.55), 25, 18, 12, PL_MIN_W][i]
        ceil = max(PL_MIN_W, ceil)
        floor = max(PL_MIN_W, min(floor, ceil))
        # closed loop: tighten while the battery drains, relax when there's surplus
        cur = self._endure_cap if self._endure_cap is not None else ceil
        bw = (self._balance or {}).get("battery_w")
        if bw is not None:
            if bw < -1 and cur > floor:
                cur = max(floor, cur - 3)
            elif bw > 2 and cur < ceil:
                cur = min(ceil, cur + 2)
        cur = max(floor, min(ceil, cur))
        self._endure_cap = cur
        self._set_cap(cur)
        # the biggest idle lever: let the discrete GPU drop to D3cold when unused
        if self.config.get("endure_gpu_sleep") and self.hw.gpu.has_runtime_pm:
            self.hw.gpu.set_runtime_pm(True)
            self._gpu_pm_dirty = True
        elif self._gpu_pm_dirty and not self.config.get("endure_gpu_sleep"):
            self.hw.gpu.set_runtime_pm(False)
            self._gpu_pm_dirty = False
        # "at all costs" panel/keyboard trims at high intensity
        if self.config.get("endure_trim") and i >= 3:
            self.hw.dim()
            self._trim_dirty = True
        elif self._trim_dirty:
            self.hw.undim()
            self._trim_dirty = False

    def _endure_teardown(self):
        """Undo Endure-only side effects (panel trims + forced dGPU runtime PM)."""
        self._endure_cap = None
        if self._trim_dirty:
            self.hw.undim()
            self._trim_dirty = False
        if self._gpu_pm_dirty:
            self.hw.gpu.set_runtime_pm(False)
            self._gpu_pm_dirty = False

    def _apply_gpu(self, emergency, battery):
        """No GPU power-capping: nvidia-smi -pl is firmware-locked on this class of
        hardware (the cap was always a no-op), and *attempting* it means polling
        the dGPU, which wakes it and steals the CPU's power budget. The one real
        GPU lever — runtime-PM D3cold sleep — is driven by the Endure mission.
        Persistence stays as an opt-in knob for desktops (off by default)."""
        g = self.hw.gpu
        if (self.config.get("gpu_persistence") and not self._gpu_pm
                and g.available):
            self._gpu_pm = g.set_persistence(True)

    def _apply_power(self, emergency, battery=False):
        """Reassert the CPU power cap (0 = leave firmware default). During an
        emergency or on battery, clamp to base TDP. When power_auto is on, scale
        the cap with temperature: cool -> full, warm -> base TDP, hot -> floor."""
        if not self.hw.has_power:
            return
        base = self.hw.power_base_w
        if emergency:
            cap = self.config.get("power_limit_w", 0)
            if base:
                cap = base if cap == 0 else min(cap, base)
        elif battery:
            # use the tuned battery point if set, else fall back to base TDP
            bw = self.config.get("battery_power_w", 0)
            if bw and bw > 0:
                cap = bw
            else:
                cap = self.config.get("power_limit_w", 0)
                if base:
                    cap = base if cap == 0 else min(cap, base)
        elif self.config.get("power_auto") and base:
            t = self.policy_temp()
            if t is None:
                cap = 0
            else:
                # smooth ramp: ceiling at quiet_below -> floor at cool_above
                lo, hi = self.config["quiet_below"], self.config["cool_above"]
                ceil = (round(self.hw.power_default_uw / 1e6)
                        if self.hw.power_default_uw else base)
                floor = self.config.get("power_floor_w") or base
                floor = max(PL_MIN_W, min(floor, ceil))
                if t <= lo:
                    cap = ceil
                elif t >= hi:
                    cap = floor
                else:
                    frac = (t - lo) / (hi - lo)
                    cap = round((ceil - (ceil - floor) * frac) / 5) * 5
        else:
            cap = self.config.get("power_limit_w", 0)

        if cap and cap > 0:
            self.hw.set_power_w(cap)        # reassert each loop, defeats drift
            self._power_dirty = True
        elif self._power_dirty:
            self.hw.restore_power()         # unmanaged again -> put default back
            self._power_dirty = False

    def _status_target_uid(self):
        cfg = self.config.get("allow_uids") or []
        if cfg:
            return cfg[0]
        try:
            us = [int(n) for n in os.listdir("/run/systemd/users")
                  if n.isdigit() and int(n) >= 1000]
            if us:
                return min(us)
        except OSError:
            pass
        return None

    def write_status(self):
        """Publish a snapshot for the pill, readable only by root + the owner."""
        try:
            os.makedirs(RUN_DIR, exist_ok=True)
            tmp = STATUS_PATH + ".tmp"
            fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o640)
            with os.fdopen(fd, "w") as f:
                json.dump(self.status(), f)
            os.replace(tmp, STATUS_PATH)
            # chmod BEFORE chown: once the file belongs to the user, a root
            # process without CAP_FOWNER (we only hold CAP_CHOWN) can no longer
            # chmod it. Setting the mode while root still owns it always works.
            uid = self._status_target_uid()
            os.chmod(STATUS_PATH, 0o640 if uid is not None else 0o644)
            if uid is not None:
                try:
                    os.chown(STATUS_PATH, uid, -1)
                except OSError:
                    pass
        except Exception as e:
            log(f"status write failed: {e}")

    def status(self):
        with self.lock:
            return {
                "ok": True,
                "version": self.version,
                "emergency": self.emergency,
                "on_battery": self.hw.on_battery(),
                "mode": self.config["mode"],
                "active_profile": self.hw.get_profile(),
                "choices": self.hw.choices,
                "level": self.level,
                "policy_temp": self.policy_temp(),
                "fans": {i: {"label": f["label"], "rpm": self.hw.read_rpm(i)}
                         for i, f in self.hw.fans.items()},
                "temps": {s: self.hw.read_temp(s) for s in self.hw.sensors},
                "sensors": list(self.hw.sensors),
                "power": {
                    "available": self.hw.has_power,
                    "limit_w": self.config.get("power_limit_w", 0),
                    "effective_limit_w": self.hw.get_power_w(),
                    "auto": self.config.get("power_auto", False),
                    "floor_w": self.config.get("power_floor_w", 0),
                    "battery_w": self.config.get("battery_power_w", 0),
                    "current_w": self.hw.get_power_w(),
                    "actual_w": self._cpu_actual_w,
                    "base_w": self.hw.power_base_w,
                    "min_w": PL_MIN_W,
                    "default_w": (round(self.hw.power_default_uw / 1e6)
                                  if self.hw.power_default_uw else None),
                },
                "gpu": self._gpu_status(),
                "cpu_pref": {
                    "turbo_available": self.hw.has_turbo,
                    "turbo": self.hw.get_turbo(),
                    "turbo_cfg": self.config.get("turbo", "auto"),
                    "epp_available": self.hw.has_epp,
                    "epp": self.hw.get_epp(),
                    "epp_cfg": self.config.get("epp", ""),
                    "battery_epp_cfg": self.config.get("battery_epp", ""),
                    "epp_choices": self.hw.epp_choices,
                },
                "cpu_clamp": self.clamp_status(),
                "mission": self.config.get("mission", ""),
                "mission_active": bool(self.config.get("mission", "")),
                "intensity": self.config.get("intensity", 2),
                "endure": {
                    "gpu_sleep": self.config.get("endure_gpu_sleep", True),
                    "trim": self.config.get("endure_trim", True),
                    "cap_w": self._endure_cap,
                    "dimmed": self._trim_dirty,
                },
                "power_balance": self._balance,
                "config": self.config,
            }

    def _gpu_status(self):
        # Read the dGPU's runtime-PM state from sysfs first — cheap, no
        # subprocess. Gpu.query() itself refuses to touch nvidia-smi while the
        # GPU is runtime-suspended (see its docstring), so calling it here
        # never wakes a sleeping GPU; it only reads telemetry off one that's
        # already awake, which is what let the platform_profile GPU-clamp
        # incident (v0.26.2) go undetected for hours — nothing was watching
        # GPU clocks, only power draw, which still looked "fine" at 16W/100%
        # util while the GPU sat pinned at pstate P8.
        g = self.hw.gpu
        rt = g.runtime_status()
        asleep = rt == "suspended"
        info = None if asleep else g.query()
        clock = info.get("clock") if info else None
        max_clock = info.get("max_clock") if info else None
        util = info.get("util") if info else None
        clamped = bool(util is not None and util >= 50 and max_clock and clock
                       and clock <= max_clock * 0.5)
        return {
            "available": g.available,
            "name": g.name,
            "runtime_pm": g.has_runtime_pm,
            "runtime_status": rt,
            "asleep": asleep,
            "power_w": info.get("draw") if info else None,
            "clock_mhz": clock,
            "max_clock_mhz": max_clock,
            "util_pct": util,
            "temp_c": info.get("temp") if info else None,
            "clamped": clamped,
        }

    def handle_cmd(self, msg):
        cmd = msg.get("cmd")
        if cmd == "get":
            return self.status()
        if cmd == "set":
            changes, rejected = {}, []
            if "mode" in msg:
                if msg["mode"] in ("auto", "manual"):
                    changes["mode"] = msg["mode"]
                else:
                    rejected.append("mode")
            if "manual_profile" in msg:
                if msg["manual_profile"] in self.hw.choices:
                    changes["manual_profile"] = msg["manual_profile"]
                else:
                    rejected.append("manual_profile")
            if "sensor" in msg:
                sv = msg["sensor"]
                if isinstance(sv, str) and (sv == "auto" or sv in self.hw.sensors):
                    changes["sensor"] = sv
                else:
                    rejected.append("sensor")
            for pk in ("power_limit_w", "power_floor_w", "battery_power_w",
                       "gpu_power_limit_w"):
                if pk in msg:
                    # 0 = unmanaged; otherwise a real number (clamped later)
                    if _coerce_num(msg[pk], 0, PL_MAX_W) is None:
                        rejected.append(pk)
                    else:
                        changes[pk] = msg[pk]
            if "power_auto" in msg:
                if isinstance(msg["power_auto"], bool):
                    changes["power_auto"] = msg["power_auto"]
                else:
                    rejected.append("power_auto")
            if "battery_aware" in msg:
                if isinstance(msg["battery_aware"], bool):
                    changes["battery_aware"] = msg["battery_aware"]
                else:
                    rejected.append("battery_aware")
            if "gpu_persistence" in msg:
                if isinstance(msg["gpu_persistence"], bool):
                    changes["gpu_persistence"] = msg["gpu_persistence"]
                else:
                    rejected.append("gpu_persistence")
            if "battery_profile" in msg:
                if msg["battery_profile"] in self.hw.choices:
                    changes["battery_profile"] = msg["battery_profile"]
                else:
                    rejected.append("battery_profile")
            if "turbo" in msg:
                if msg["turbo"] in ("auto", "on", "off"):
                    changes["turbo"] = msg["turbo"]
                else:
                    rejected.append("turbo")
            for ek in ("epp", "battery_epp"):
                if ek in msg:
                    ev = msg[ek]
                    if isinstance(ev, str) and (ev == "" or ev in VALID_EPP):
                        changes[ek] = ev
                    else:
                        rejected.append(ek)
            if "mission" in msg:
                if msg["mission"] in ("",) + MISSIONS:
                    changes["mission"] = msg["mission"]
                else:
                    rejected.append("mission")
            if "intensity" in msg:
                iv = _coerce_num(msg["intensity"], 0, INTENSITY_MAX)
                if iv is None:
                    rejected.append("intensity")
                else:
                    changes["intensity"] = int(iv)
            for bk in ("endure_gpu_sleep", "endure_trim"):
                if bk in msg:
                    if isinstance(msg[bk], bool):
                        changes[bk] = msg[bk]
                    else:
                        rejected.append(bk)
            for k, (lo, hi) in NUM_LIMITS.items():
                if k in msg:
                    cv = _coerce_num(msg[k], lo, hi)
                    if cv is None:
                        rejected.append(k)
                    else:
                        changes[k] = cv
            # A mission owns the whole stance, so a raw stance knob and a mission
            # are mutually exclusive. If the caller explicitly drives a raw knob,
            # drop the active mission — otherwise the mission silently overrides
            # the knob every control loop (the "I set Perf but it stays Cool" trap).
            # Switching to an explicit profile is a stance change → leave the
            # mission. We intentionally do NOT clear on sub-knobs (turbo/epp/power):
            # a mission keeps owning those, and a chatty client echoing them back
            # must never silently drop the active mission.
            LEGACY_STANCE_KEYS = ("mode", "manual_profile")
            if ("mission" not in changes and self.config.get("mission")
                    and any(k in changes for k in LEGACY_STANCE_KEYS)):
                changes["mission"] = ""
            with self.lock:
                if changes and not self._rate_ok():
                    return {"ok": False, "error": "rate limited"}
                before = dict(self.config)
                self.config.update(changes)
                # re-clamp everything + enforce failsafe invariants
                sanitize_config(self.config, self.hw.choices, self.hw.sensors)
                changed = self.config != before
            self.apply_once()
            if changed:
                self.save_config()
            resp = self.status()
            if rejected:
                log(f"rejected invalid set fields: {rejected}")
                resp["rejected"] = rejected
            return resp
        return {"ok": False, "error": f"unknown cmd {cmd}"}

    # ---- socket ---- #
    def serve_socket(self):
        try:
            os.unlink(SOCK_PATH)
        except FileNotFoundError:
            pass
        os.makedirs(RUN_DIR, exist_ok=True)
        srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        srv.bind(SOCK_PATH)
        srv.listen(8)
        srv.settimeout(1.0)
        # Perms are a first gate; SO_PEERCRED below is the real authorization.
        os.chmod(SOCK_PATH, 0o660)
        uid = self._status_target_uid()
        if uid is not None:
            try:
                os.chown(SOCK_PATH, uid, -1)   # only this user (+root) can connect
            except OSError:
                pass
        else:
            os.chmod(SOCK_PATH, 0o666)         # no user known; rely on SO_PEERCRED
        log(f"listening on {SOCK_PATH}")
        while not self._stop.is_set():
            try:
                conn, _ = srv.accept()
            except socket.timeout:
                continue
            except OSError:
                break
            with conn:
                try:
                    conn.settimeout(1.0)
                    creds = conn.getsockopt(socket.SOL_SOCKET, socket.SO_PEERCRED,
                                            struct.calcsize("3i"))
                    pid, uid, _gid = struct.unpack("3i", creds)
                    if uid not in self.allowed_uids():
                        log(f"DENIED connection from uid={uid} pid={pid}")
                        resp = {"ok": False, "error": "unauthorized"}
                        conn.sendall((json.dumps(resp) + "\n").encode())
                        continue
                    data = b""
                    while b"\n" not in data:
                        chunk = conn.recv(4096)
                        if not chunk:
                            break
                        data += chunk
                        if len(data) > MAX_MSG_BYTES:
                            raise ValueError("message too large")
                    if not data:
                        continue
                    msg = json.loads(data.split(b"\n", 1)[0])
                    if not isinstance(msg, dict):
                        raise ValueError("message must be a JSON object")
                    resp = self.handle_cmd(msg)
                except Exception as e:
                    resp = {"ok": False, "error": str(e)}
                try:
                    conn.sendall((json.dumps(resp) + "\n").encode())
                except OSError:
                    pass
        srv.close()

    # ---- lifecycle ---- #
    def restore(self):
        name = next((n for n in RESTORE_NAMES if n in self.hw.choices),
                    self.hw.choices[0])
        log(f"restoring profile -> {name}")
        try:
            self.hw.set_profile(name)
            self.hw.restore_power()
            if self._turbo_dirty:
                self.hw.set_turbo(True)        # leave boost enabled (neutral)
            if self._epp_dirty and "default" in self.hw.epp_choices:
                self.hw.set_epp("default")
            self._endure_teardown()            # un-dim panel/kbd, free dGPU runtime PM
            self.hw.gpu.restore()
        except Exception as e:
            log(f"restore error: {e}")

    def run(self):
        atexit.register(self.restore)

        def on_signal(signum, _f):
            log(f"signal {signum} — stopping")
            self._stop.set()
        signal.signal(signal.SIGTERM, on_signal)
        signal.signal(signal.SIGINT, on_signal)

        threading.Thread(target=self.serve_socket, daemon=True).start()
        log("control loop started")
        while not self._stop.is_set():
            try:
                self.apply_once()
            except Exception:
                log("apply error:\n" + traceback.format_exc())
            self._stop.wait(self.config.get("poll_interval", 3.0))
        self.restore()


def selftest():
    """Verify the controllable hardware is reachable. Exit 0 = healthy."""
    try:
        hw = Hardware()
    except SystemExit as e:
        print(f"FAIL: {e}")
        return 1
    ok = True
    prof = hw.get_profile()
    print(f"profile      : {prof}  (choices: {' '.join(hw.choices)})")
    if prof not in hw.choices:
        ok = False
    print(f"sensors      : {len(hw.sensors)} temp, {len(hw.fans)} fan")
    print(f"watchdog     : {hw.crit_sensor_ids}  -> {hw.max_crit_temp()}°C")
    print(f"cpu power    : {'yes ' + str(hw.get_power_w()) + 'W' if hw.has_power else 'n/a'}")
    turbo = ("on" if hw.get_turbo() else "off") if hw.has_turbo else "n/a"
    print(f"turbo        : {turbo}")
    epp_choices = ' '.join(hw.epp_choices) or 'none'
    print(f"epp          : {hw.get_epp() or 'n/a'}  (choices: {epp_choices})")
    cmax, fmin, fmax = hw.cpu_freq_mhz()
    print(f"cpu freq     : {cmax or '?'} MHz now  (range {fmin or '?'}–{fmax or '?'} MHz)")
    rt = hw.gpu.runtime_status()
    print(f"gpu          : {hw.gpu.name if hw.gpu.available else 'n/a'}"
          f"{f'  (runtime PM: {rt})' if hw.gpu.has_runtime_pm else ''}")
    bl = "yes" if hw.backlight else "no"
    print(f"trims        : panel backlight {bl}, {len(hw.kbd_leds)} kbd led(s)")
    if hw.max_crit_temp() is None:
        ok = False
    print("RESULT       :", "OK" if ok else "DEGRADED")
    return 0 if ok else 1


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "--selftest":
        sys.exit(selftest())
    if os.geteuid() != 0:
        sys.exit("phanspeedd must run as root.")
    Daemon().run()


if __name__ == "__main__":
    main()
