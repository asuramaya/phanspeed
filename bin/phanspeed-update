#!/usr/bin/env python3
# SPDX-License-Identifier: GPL-3.0-or-later
# Copyright (C) 2026 asuramaya and PhanSpeed contributors
"""phanspeed-update — pull newer PhanSpeed releases from GitHub and install them.

Thin wrapper over the vendored sutra_update.py (UNIFY.md Wave A #1, the
family's shared update spine): one grammar, one trust chain, one
install-path detection, shared fleet-wide instead of six hand-rolled
copies. This file supplies only what's phanspeed-specific — the repo slug,
the installed-version lookup (dpkg first, VERSION file fallback for a
source install), and where the signing anchor lives.

  phanspeed-update --check [--json]   notify tier (default): report only
  phanspeed-update                    manual install tier (explicit consent —
                                       this is what the pill's polkit prompt
                                       runs; that click-tier is unchanged,
                                       it just execs this binary bare)
  phanspeed-update --auto             timer tier — inert here, since
                                       phanspeed has no auto_update config
                                       toggle (v0.25.0's deliberate choice:
                                       installs stay notify+click, never
                                       unattended); the daily timer only
                                       ever passes --check.

This is deliberately a SEPARATE program from the daemon: phanspeedd is
hardened with no network access at all (IPAddressDeny=any), so the one
component that reaches the internet is this small, isolated updater —
never the privileged control loop.
"""
import os
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import sutra_update  # noqa: E402

REPO_SLUG = "asuramaya/phanspeed"
PILL = "phanspeed"
VERSION_FILE = "/usr/share/phanspeed/VERSION"
_SRC_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
ANCHOR_CANDIDATES = (
    "/usr/share/phanspeed/allowed_signers",
    os.path.join(_SRC_DIR, "release-signing", "allowed_signers"),
)


def deb_version():
    """The dpkg-registered package version, or None if not a .deb install."""
    try:
        out = subprocess.check_output(
            ["dpkg-query", "-W", "-f=${Version}", PILL],
            stderr=subprocess.DEVNULL)
        return out.decode().strip() or None
    except Exception:
        return None


def installed_version():
    """Best-effort version for display/--check: dpkg first, else the VERSION
    file a source install writes."""
    v = deb_version()
    if v:
        return v
    try:
        with open(VERSION_FILE) as f:
            return f.read().strip()
    except OSError:
        return None


if __name__ == "__main__":
    cur = installed_version()
    if cur is None:
        print("PhanSpeed not detected; nothing to update.")
        sys.exit(0)
    sys.exit(sutra_update.main(
        pill=PILL, slug=REPO_SLUG, installed_version=cur,
        anchor_candidates=list(ANCHOR_CANDIDATES), auto_enabled=False))
